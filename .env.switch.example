# Config for scripts/switch-account.sh (PC side)
# Copy to .env.switch and fill in your values. .env.switch is NOT committed to git.

# SSH target where the gateway runs (e.g. ubuntu@1.2.3.4 or alias from ~/.ssh/config)
VPS_HOST=user@your-vps-ip

# Absolute path to the gateway repo on the VPS
VPS_PATH=~/devin-claude-gateway
