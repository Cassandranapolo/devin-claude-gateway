# Server
PORT=3000
HOST=0.0.0.0

# Optional: gateway-level API key clients must send to use this proxy.
# If empty, the gateway accepts any request (NOT recommended in production).
GATEWAY_API_KEY=

# Path where the gateway persists resolved org_id, bearer cache, etc.
STATE_FILE=./data/state.json

# --- Devin auth (at minimum, set DEVIN_BEARER) ---

# REQUIRED unless you also set a complete DEVIN_COOKIE that contains the
# auth1 session: the opaque bearer token Devin sends as `Authorization`.
# As of late 2025 it is stored in localStorage under key `auth1_session`
# (JSON; the `.token` field). It looks like:
#   auth1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get it via DevTools Console at https://app.devin.ai:
#   JSON.parse(localStorage.getItem('auth1_session')).token
DEVIN_BEARER=

# Optional: cookie string for any additional non-auth cookies Devin sets
# (datadog session, feature flags, etc). Run `document.cookie` in the
# DevTools Console of a logged-in tab. Single line, no surrounding quotes.
# Often not strictly required when DEVIN_BEARER and DEVIN_ORG_ID are set.
DEVIN_COOKIE=

# Recommended: pin the internal org id to bypass auto-resolve.
# Get it via DevTools Console:
#   localStorage.getItem('last-internal-org-for-external-org-v1-null')
# It looks like `org-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx`.
DEVIN_ORG_ID=

# Optional: which Devin model to request. Defaults to devin-opus-4-7.
# Other valid values: devin-2-5, devin-0929-brocade.
DEVIN_MODEL_DEFAULT=devin-opus-4-7

# Optional: extra model aliases. Format: "from1=to1,from2=to2".
# `from` is the model name your client sends (case-insensitive); `to` must be
# one of the valid Devin model ids: devin-opus-4-7, devin-2-5, devin-0929-brocade.
# Custom aliases take priority over the built-in claude-* mappings.
# Example: lets clients ask for `gpt-4o` and get routed to devin-2-5:
#   MODEL_ALIASES=gpt-4=devin-opus-4-7,gpt-4o=devin-2-5,o1=devin-opus-4-7
MODEL_ALIASES=

# Optional: how many seconds to wait for Devin's first reply before timeout.
DEVIN_REPLY_TIMEOUT_S=180

# Optional: planning settings (mirrors Devin web defaults)
DEVIN_PLANNER_TYPE=fast
DEVIN_PLANNING_MODE=automatic

# Optional: username shown to Devin (cosmetic in some prompts)
DEVIN_USERNAME=User

# --- Auto-refresh (optional, used by scripts/refresh-bearer.cjs) ---
# Path to the Playwright storage state file produced by --bootstrap.
# Default: ./data/devin-state.json
# DEVIN_STATE_FILE=./data/devin-state.json
